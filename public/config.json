{
    "workflowApiVersion": "1.1",
    "metaData": {
       "icon": "images/iconSmall.png",
       "category": "message"
    },
    "type": "REST",
    "lang": {
       "en-US": {
           "name": "Twilio SMS",
           "description": "Send Twilio SMS with Journey Builder"
       }
    },
    "arguments": {
        "execute": {
            "inArguments": [
                {
                    "email": "{{Contact.Default.EmailAddress}}",
                    "to":    "{{Contact.Attribute.Twilio_SMS_DE.Phone}}"
                }
            ],
            "outArguments": [],
            "url":     "https://customactivity-sfmc.onrender.com/journeybuilder/execute",
            "verb":    "POST",
            "body":    "",
            "format":  "json",
            "useJwt":  false,
            "timeout": 10000
        }
    },
    "configurationArguments": {
        "applicationExtensionKey": "REPLACE_WITH_YOUR_SFMC_UNIQUE_KEY",
        "save": {
            "url":     "https://customactivity-sfmc.onrender.com/journeybuilder/save",
            "verb":    "POST",
            "body":    "",
            "format":  "json",
            "useJwt":  false,
            "timeout": 10000
        },
        "publish": {
            "url":     "https://customactivity-sfmc.onrender.com/journeybuilder/publish",
            "verb":    "POST",
            "body":    "",
            "format":  "json",
            "useJwt":  false,
            "timeout": 10000
        },
        "validate": {
            "url":     "https://customactivity-sfmc.onrender.com/journeybuilder/validate",
            "verb":    "POST",
            "body":    "",
            "format":  "json",
            "useJwt":  false,
            "timeout": 10000
        },
        "stop": {
            "url":     "https://customactivity-sfmc.onrender.com/journeybuilder/stop",
            "verb":    "POST",
            "body":    "",
            "format":  "json",
            "useJwt":  false,
            "timeout": 10000
        }
    },
    "wizardSteps": [
        { "label": "Create SMS Message", "key": "step1" }
    ],
    "userInterfaces": {
        "configModal": {
            "height": 600,
            "width":  800,
            "fullscreen": false
        }
    },
    "schema": {
        "arguments": {
            "execute": {
                "inArguments": [
                    {
                        "accountSid": {
                            "dataType":   "String",
                            "isNullable": false,
                            "direction":  "out"
                        }
                    },
                    {
                        "authToken": {
                            "dataType":   "String",
                            "isNullable": false,
                            "direction":  "out"
                        }
                    },
                    {
                        "messagingService": {
                            "dataType":   "String",
                            "isNullable": false,
                            "direction":  "out"
                        }
                    },
                    {
                        "to": {
                            "dataType":   "Phone",
                            "isNullable": false,
                            "direction":  "out"
                        }
                    },
                    {
                        "body": {
                            "dataType":   "String",
                            "isNullable": false,
                            "direction":  "out"
                        }
                    },
                    {
                        "email": {
                            "dataType":   "Email",
                            "isNullable": true,
                            "direction":  "out"
                        }
                    }
                ],
                "outArguments": []
            }
        }
    }
}
